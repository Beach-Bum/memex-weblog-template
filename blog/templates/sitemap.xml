{% autoescape off %}<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>{{ site_url }}/</loc><priority>1.0</priority></url>
  <url><loc>{{ site_url }}/research/</loc><priority>0.9</priority></url>
  <url><loc>{{ site_url }}/graph/</loc><priority>0.8</priority></url>
  {% for article in articles %}
  <url>
    <loc>{{ site_url }}{{ article.get_absolute_url }}</loc>
    {% if article.published_date %}<lastmod>{{ article.published_date|date:"Y-m-d" }}</lastmod>{% endif %}
    <priority>0.7</priority>
  </url>
  {% endfor %}
</urlset>{% endautoescape %}
