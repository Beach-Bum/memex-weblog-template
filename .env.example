# Site identity
SITE_NAME=Your Research Program
SITE_AUTHOR=Your Name
SITE_THESIS=Your research thesis goes here.
SITE_DESCRIPTION=A structured research program, not a blog.
SITE_URL=http://localhost:8000

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database (optional — falls back to SQLite)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Or individual vars:
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=memex
# DB_PORT=5432
